{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "baseBranchPatterns": [
    "bleeding"
  ],
  "prHourlyLimit": 0,
  "prConcurrentLimit": 0,
  "packageRules": [
    {
      "matchUpdateTypes": [
        "minor",
        "patch",
        "pin",
        "digest"
      ],
      "automerge": true
    },
    {
      "matchDepTypes": [
        "devDependencies"
      ],
      "automerge": true
    },
    {
      "matchPackageNames": "org.jetbrains.kotlinx:kotlinx-datetime",
      "allowedVersions": "!/^.+-compat$/"
    },
    {
      "description": "Allow beta and rc for androidx libraries as these are considered stable",
      "matchPackageNames": [
        "androidx.*"
      ],
      "ignoreUnstable": false,
      "allowedVersions": "/^[0-9]+\\.[0-9]+(\\.[0-9]+)?(-(?:beta|rc)[0-9]+)?$/"
    }
  ],
  "platformAutomerge": true,
  "labels": [
    "{{parentDir}}"
  ]
}
